# String de conexão do MySQL usada pela aplicação.
#
# Padrão (alunos): MySQL do docker-compose — o run.bat sobe esse container automaticamente.
DATABASE_URL=mysql+pymysql://chatbot_app:chatbot_app_pass@localhost:3306/chatbot
#
# Alternativa 1 — MySQL instalado localmente na máquina (ajuste usuário/senha):
# DATABASE_URL=mysql+pymysql://root:senha@127.0.0.1:3306/chatbot
#
# Alternativa 2 — banco na nuvem (AWS RDS). Use o endpoint do RDS como host.
# O run.bat detecta que é remoto e NÃO sobe o MySQL do Docker. Passo a passo: TUTORIAL.md.
# DATABASE_URL=mysql+pymysql://admin:SUA_SENHA@meu-banco.xxxx.us-east-1.rds.amazonaws.com:3306/chatbot

# TLS do banco (recomendado pela AWS para RDS). Aponte para o CA bundle baixado da AWS.
# Baixe em: https://truststore.pki.rds.amazonaws.com/global/global-bundle.pem
# Deixe vazio para bancos locais (sem TLS). Use barras normais no caminho.
# DB_SSL_CA=C:/Users/voce/certs/global-bundle.pem
DB_SSL_CA=

# Variáveis lidas só pelo docker-compose.yml (Opção B)
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_DATABASE=chatbot
MYSQL_USER=chatbot_app
MYSQL_PASSWORD=chatbot_app_pass

# JWT do painel
JWT_SECRET_KEY=troque-esta-chave-em-producao
JWT_EXPIRE_MINUTES=480

# Redis (usado nas fases futuras — sessão de admin no chat)
REDIS_URL=redis://localhost:6379/0

# A chave do Groq NÃO fica aqui: é cadastrada pelo admin na tela de onboarding do
# painel (/painel/integracao/groq) e salva no banco (configuracoes.groq_api_key).

# WhatsApp — provedor de conexão.
#   evolution = conexão REAL via Evolution API (Docker) por QR Code — padrão.
#   baileys   = conexão real via sidecar Node (pasta whatsapp-service/).
#   fake      = dublê só para os testes automatizados.
WHATSAPP_PROVIDER=evolution
WHATSAPP_SERVICE_URL=http://localhost:3001
# Secret que protege POST /webhook/whatsapp (a Evolution envia no header X-Webhook-Secret).
WHATSAPP_WEBHOOK_SECRET=troque-este-secret-do-webhook
# Tempo de vida (segundos) do QR exibido no painel.
PAIRING_TTL_SECONDS=60

# Evolution API (provider 'evolution') — o stack sobe em evolution/docker-compose.yml
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=chatbot-evo-key-2026
EVOLUTION_INSTANCE=chatbot
# URL que a Evolution (dentro do Docker) usa para chamar o webhook no host (Docker Desktop).
EVOLUTION_WEBHOOK_URL=http://host.docker.internal:8000/webhook/whatsapp
