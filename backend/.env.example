# ============================================================================
# 1) BANCO DE DADOS (AWS RDS)  ->  OBRIGATORIO PREENCHER
# ============================================================================
# Este projeto NAO usa banco local: os dados ficam no SEU MySQL criado no AWS RDS.
#
# Onde achar cada valor:
#   Console da AWS -> servico RDS -> Databases -> clique no seu banco
#
#   ENDPOINT  ->  aba "Connectivity & security", campo "Endpoint"
#                 ex.: chatbot.c9xyzabc123.us-east-1.rds.amazonaws.com
#   PORTA     ->  mesma aba, campo "Port" (normalmente 3306)
#   USUARIO   ->  o "Master username" que voce definiu ao criar o banco (ex.: admin)
#   SENHA     ->  a "Master password" que voce definiu ao criar o banco
#   BANCO     ->  aba "Configuration", campo "DB name"
#                 (e o "Initial database name" que voce informou na criacao)
#
# Monte a linha abaixo trocando os valores em MAIUSCULO:
#
#   DATABASE_URL=mysql+pymysql://USUARIO:SENHA@ENDPOINT:PORTA/BANCO
#
# Exemplo (e so um modelo, NAO use estes dados):
#   DATABASE_URL=mysql+pymysql://admin:MinhaSenha123@chatbot.c9xyzabc123.us-east-1.rds.amazonaws.com:3306/chatbot
#
# ATENCAO - se a SENHA tiver caracteres especiais, substitua-os aqui:
#   @ vira %40    : vira %3A    / vira %2F    ? vira %3F    # vira %23
#
DATABASE_URL=

# ---------------------------------------------------------------------------
# TLS/SSL do RDS (opcional, mas recomendado pela AWS)
# ---------------------------------------------------------------------------
# 1. Baixe o certificado: https://truststore.pki.rds.amazonaws.com/global/global-bundle.pem
# 2. Salve num caminho simples e informe abaixo, usando barras normais "/".
# Deixe vazio para conectar sem TLS.
#   ex.: DB_SSL_CA=C:/Users/seu-usuario/Downloads/global-bundle.pem
DB_SSL_CA=

# ---------------------------------------------------------------------------
# 1b) BANCO DE TRABALHO DO ALUNO (opcional)
# ---------------------------------------------------------------------------
# Onde as ROTAS DE IA leem e gravam (as tabelas que VOCE cria: alunos, produtos...).
# Deixe vazio para usar o mesmo banco da aplicacao.
#
# Nao precisa preencher aqui: da para configurar pelo painel, em
#   Configuracoes -> Banco de trabalho (aluno)
#
# Vantagem de separar: o "Apagar tudo" nao toca nas suas tabelas, e as tabelas
# internas do chatbot (senhas, chave da IA) ficam invisiveis para a IA.
DADOS_DATABASE_URL=
DADOS_DB_SSL_CA=

# ============================================================================
# 2) PAINEL
# ============================================================================
# Chave usada para assinar o login do painel. Troque por qualquer texto secreto.
JWT_SECRET_KEY=troque-esta-chave-por-um-texto-secreto
JWT_EXPIRE_MINUTES=480

# ============================================================================
# 3) INTELIGENCIA ARTIFICIAL (Groq)
# ============================================================================
# A chave do Groq NAO fica aqui: voce cadastra pelo painel, na tela "Chave Groq"
# (/painel/integracao/groq). Ela e validada na hora e salva no banco.

# ============================================================================
# 4) WHATSAPP
# ============================================================================
# evolution = conexao REAL por QR Code, via Evolution API (sobe no Docker) - padrao
# baileys   = conexao real via sidecar Node (pasta whatsapp-service/)
# fake      = dublê usado apenas pelos testes automatizados
WHATSAPP_PROVIDER=evolution
WHATSAPP_SERVICE_URL=http://localhost:3001
# Secret que protege o POST /webhook/whatsapp (a Evolution envia no header X-Webhook-Secret).
WHATSAPP_WEBHOOK_SECRET=troque-este-secret-do-webhook
# Tempo de vida (segundos) do QR Code exibido no painel.
PAIRING_TTL_SECONDS=60

# Evolution API - o stack sobe sozinho (evolution/docker-compose.yml). Nao precisa mexer.
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=chatbot-evo-key-2026
EVOLUTION_INSTANCE=chatbot
# URL que a Evolution (dentro do Docker) usa para chamar o webhook no host.
EVOLUTION_WEBHOOK_URL=http://host.docker.internal:8000/webhook/whatsapp

# Redis (reservado para fases futuras - nao precisa mexer)
REDIS_URL=redis://localhost:6379/0
