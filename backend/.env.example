# ============================================================================
# COMO OS DOIS BANCOS FUNCIONAM
# ============================================================================
# 1) BANCO DA APLICACAO (abaixo) - LOCAL, no Docker. Guarda so a configuracao do
#    chatbot (empresa, admins, rotas, conversas). Ja vem pronto: o run.bat sobe o
#    container e voce NAO precisa mexer em nada aqui.
#
# 2) BANCO DO SEU PROJETO - fica na AWS RDS. E o banco que VOCE cria na aula
#    (restaurante, loja, escola...) e onde as rotas de IA leem e gravam.
#    Voce configura ele PELA TELA do painel, nao aqui.
# ============================================================================

# ============================================================================
# 1) BANCO DA APLICACAO (local, Docker) - nao precisa mexer
# ============================================================================
# Porta 3307 de proposito: nao conflita com um MySQL ja instalado na maquina.
DATABASE_URL=mysql+pymysql://chatbot_app:chatbot_app_pass@localhost:3307/chatbot

# Credenciais lidas pelo docker-compose.yml do proprio backend.
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_DATABASE=chatbot
MYSQL_USER=chatbot_app
MYSQL_PASSWORD=chatbot_app_pass

# TLS do banco da aplicacao (nao usado no Docker local). Deixe vazio.
DB_SSL_CA=

# ============================================================================
# 2) BANCO DO SEU PROJETO (AWS RDS) - configure PELA TELA do painel
# ============================================================================
# E o banco que voce cria na aula (restaurante, loja, escola...). E dele que as
# ROTAS DE IA leem e gravam.
#
# NAO preencha aqui: ao abrir o painel pela primeira vez, a tela pede esses dados
# e mostra onde achar cada um no console da AWS. Depois, para trocar:
#   Configuracoes -> Banco do meu projeto (AWS)
#
# Estas linhas sao preenchidas automaticamente quando voce salva pela tela.
DADOS_DATABASE_URL=
DADOS_DB_SSL_CA=

# ============================================================================
# 2) PAINEL
# ============================================================================
# Chave usada para assinar o login do painel. Troque por qualquer texto secreto.
JWT_SECRET_KEY=troque-esta-chave-por-um-texto-secreto
JWT_EXPIRE_MINUTES=480

# ============================================================================
# 3) INTELIGENCIA ARTIFICIAL (Groq)
# ============================================================================
# A chave do Groq NAO fica aqui: voce cadastra pelo painel, na tela "Chave Groq"
# (/painel/integracao/groq). Ela e validada na hora e salva no banco.

# ============================================================================
# 4) WHATSAPP
# ============================================================================
# evolution = conexao REAL por QR Code, via Evolution API (sobe no Docker) - padrao
# baileys   = conexao real via sidecar Node (pasta whatsapp-service/)
# fake      = dublê usado apenas pelos testes automatizados
WHATSAPP_PROVIDER=evolution
WHATSAPP_SERVICE_URL=http://localhost:3001
# Secret que protege o POST /webhook/whatsapp (a Evolution envia no header X-Webhook-Secret).
WHATSAPP_WEBHOOK_SECRET=troque-este-secret-do-webhook
# Tempo de vida (segundos) do QR Code exibido no painel.
PAIRING_TTL_SECONDS=60

# Evolution API - o stack sobe sozinho (evolution/docker-compose.yml). Nao precisa mexer.
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=chatbot-evo-key-2026
EVOLUTION_INSTANCE=chatbot
# URL que a Evolution (dentro do Docker) usa para chamar o webhook no host.
EVOLUTION_WEBHOOK_URL=http://host.docker.internal:8000/webhook/whatsapp

# Redis (reservado para fases futuras - nao precisa mexer)
REDIS_URL=redis://localhost:6379/0
